using System;
using System.Collections.Generic;
using System.Drawing;
using System.Linq;
using System.Windows.Forms;
namespace SnakeGame
{
public partial class Form1 : Form
{
private List snake = new List();
private Point food;
private string direction = “RIGHT”;
private Timer timer = new Timer();
private Random random = new Random();
private int score = 0;
    public Form1()
    {
        InitializeComponent();

        this.Width = 620;
        this.Height = 640;
        this.DoubleBuffered = true;

        timer.Interval = 100;
        timer.Tick += UpdateGame;
        timer.Start();

        StartGame();

        this.KeyDown += GameKeyDown;
        this.Paint += DrawGame;
    }

    private void StartGame()
    {
        snake.Clear();
        snake.Add(new Point(5, 5));

        SpawnFood();
        score = 0;
    }

    private void SpawnFood()
    {
        food = new Point(
            random.Next(0, 30),
            random.Next(0, 30));
    }

    private void UpdateGame(object sender, EventArgs e)
    {
        Point head = snake.First();

        switch (direction)
        {
            case "UP":
                head.Y--;
                break;
            case "DOWN":
                head.Y++;
                break;
            case "LEFT":
                head.X--;
                break;
            case "RIGHT":
                head.X++;
                break;
        }

        if (head.X < 0 || head.Y < 0 ||
            head.X >= 30  head.Y >= 30 
            snake.Contains(head))
        {
            timer.Stop();
            MessageBox.Show($"Game Over! Score: {score}");
            StartGame();
            timer.Start();
            return;
        }

        snake.Insert(0, head);

        if (head == food)
        {
            score++;
            SpawnFood();
        }
        else
        {
            snake.RemoveAt(snake.Count - 1);
        }

        Invalidate();
    }

    private void DrawGame(object sender, PaintEventArgs e)
    {
        Graphics g = e.Graphics;

        foreach (var part in snake)
        {
            g.FillRectangle(
                Brushes.LimeGreen,
                part.X * 20,
                part.Y * 20,
                20,
                20);
        }

        g.FillEllipse(
            Brushes.Red,
            food.X * 20,
            food.Y * 20,
            20,
            20);

        g.DrawString(
            $"Score: {score}",
            Font,
            Brushes.White,
            10,
            10);
    }

    private void GameKeyDown(object sender, KeyEventArgs e)
    {
        if (e.KeyCode == Keys.Up && direction != "DOWN")
            direction = "UP";

        if (e.KeyCode == Keys.Down && direction != "UP")
            direction = "DOWN";

        if (e.KeyCode == Keys.Left && direction != "RIGHT")
            direction = "LEFT";

        if (e.KeyCode == Keys.Right && direction != "LEFT")
            direction = "RIGHT";
    }
}
}
